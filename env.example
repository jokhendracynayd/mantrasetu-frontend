# API Configuration
REACT_APP_API_URL=http://localhost:3000/api/v1

# App Configuration
REACT_APP_APP_NAME=MantraSetu
REACT_APP_APP_VERSION=1.0.0
REACT_APP_APP_DESCRIPTION=Digital Spiritual Platform

# Environment
REACT_APP_NODE_ENV=development

# Features
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=true

# Payment Gateway (Razorpay)
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id

# Video Streaming
REACT_APP_ZOOM_SDK_KEY=your_zoom_sdk_key
REACT_APP_ZOOM_SDK_SECRET=your_zoom_sdk_secret

# WebRTC Configuration
REACT_APP_WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
REACT_APP_WEBRTC_TURN_SERVER=your_turn_server

# File Upload
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Social Login (Optional)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id
REACT_APP_MIXPANEL_TOKEN=your_mixpanel_token

# Error Tracking (Optional)
REACT_APP_SENTRY_DSN=your_sentry_dsn

# Feature Flags
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_VIDEO_CALL=true
REACT_APP_ENABLE_PAYMENT=true
REACT_APP_ENABLE_NOTIFICATIONS=true
